# Release signing config template for SNI Scanner Android.
#
# Copy this file to `keystore.properties` (same directory) and fill in your
# own values. `keystore.properties` is gitignored — NEVER commit it.
#
# All paths in this file are resolved relative to this directory
# (src-tauri/keystore/) by the Gradle build script. The storeFile value can
# be either a bare filename (resolved relative to this directory) or an
# absolute path.
#
# Setup instructions: see src-tauri/keystore/README.md

# Keystore file (bare filename — resolved relative to this directory)
storeFile=release.keystore

# Password protecting the keystore as a whole
storePassword=YOUR_STORE_PASSWORD_HERE

# Alias of the signing key inside the keystore
keyAlias=release

# Password protecting the signing key (often the same as storePassword)
keyPassword=YOUR_KEY_PASSWORD_HERE
