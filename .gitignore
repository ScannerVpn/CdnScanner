# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log
# Skills directory
/skills/

# Tauri — ignore build cache, but track final bundled EXE + installers
src-tauri/target/
src-tauri/target/*
!/src-tauri/target/release/
!/src-tauri/target/release/sni-scanner.exe
!/src-tauri/target/release/bundle/
!/src-tauri/target/release/bundle/nsis/
!/src-tauri/target/release/bundle/nsis/*
!/src-tauri/target/release/bundle/msi/
!/src-tauri/target/release/bundle/msi/*
src-tauri/WixTools/
src-tauri/Frameworks/

# Build output
/dist/
*.apk
# Note: src-tauri/gen/ is NOT ignored — the generated Android project at
# src-tauri/gen/android/ is tracked. Its own .gitignore (at
# src-tauri/gen/android/app/.gitignore) excludes the truly transient files
# (jniLibs/*.so, generated sources, tauri.build.gradle.kts, etc.). This is
# important for the release signing config in build.gradle.kts to survive
# future `tauri android init` regenerations.

# Temporary API folder (auto-moved by scripts/build-static.js during Tauri static build)
/.api-temp/
/out/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db
desktop.ini/frames/
/.chrome-profile/
/gif-check/
/sni-stop3/
/sni-stop-test/
/sni-stop-test2/
/sni-stop*/

# Android release signing — NEVER commit the keystore or its credentials
/src-tauri/keystore/*.keystore
/src-tauri/keystore/*.jks
/src-tauri/keystore/keystore.properties
!/src-tauri/keystore/keystore.properties.example

# Generated Android project — track it, but exclude machine-specific + build output
**/local.properties
/src-tauri/gen/android/.gradle/
/src-tauri/gen/android/.idea/
/src-tauri/gen/android/.externalNativeBuild/
/src-tauri/gen/android/app/.externalNativeBuild/
/src-tauri/gen/android/captures/
/src-tauri/gen/android/app/build/
/src-tauri/gen/android/app/release/
/src-tauri/gen/android/app/debug/
/src-tauri/gen/android/build/
/src-tauri/gen/android/app/.cxx/
*.iml

